   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🔹 Problemas Inversos e Calibração de Parâmetros\n",
    "## Apêndice | Nível: Pós-Graduação\n",
    "\n",
    "**Objetivos de aprendizagem:**\n",
    "- Formular problemas inversos como minimização de função custo\n",
    "- Implementar Levenberg-Marquardt para estimação não-linear\n",
    "- Calcular matriz de covariância e intervalos de confiança\n",
    "- Analisar correlação entre parâmetros e identificabilidade\n",
    "\n",
    "**Referência:** Lugon Junior et al. (2026), Apêndice; Lugon Jr. et al. (2008)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.optimize import least_squares\n",
    "from scipy.special import erf\n",
    "\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (10, 6)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔸 Função Custo e Sensibilidades"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def modelo_gaussiana_1d(x, M, U, E, t, x0=0):\n",
    "    \"\"\"\n",
    "    Solução analítica para advecção-difusão 1D (lançamento instantâneo).\n",
    "    \"\"\"\n",
    "    sigma = np.sqrt(2 * E * t)\n",
    "    return (M / (np.sqrt(2*np.pi) * sigma)) * np.exp(-(x - x0 - U*t)**2 / (2*sigma**2))\n",
    "\n",
    "def residuos(params, x_obs, C_obs, U, t, x0=0):\n",
    "    \"\"\"\n",
    "    Vetor de resíduos para calibração de M e E.\n",
    "    \"\"\"\n",
    "    M, E = params\n",
    "    if M <= 0 or E <= 0:\n",
    "        return np.full_like(C_obs, 1e10)  # penalizar parâmetros não-físicos\n",
    "    C_calc = modelo_gaussiana_1d(x_obs, M, U, E, t, x0)\n",
    "    return C_calc - C_obs\n",
    "\n",
    "# Gerar dados sintéticos com ruído\n",
    "np.random.seed(42)\n",
    "\n",
    "# Parâmetros \"verdadeiros\"\n",
    "M_true = 35.0      # kg\n",
    "U_true = 0.20      # m/s\n",
    "E_true = 12.6      # m²/s (Rio Macaé)\n",
    "t_obs = 4 * 3600   # 4 horas\n",
    "\n",
    "# Pontos de observação\n",
    "x_obs = np.linspace(2500, 6000, 15)\n",
    "C_true = modelo_gaussiana_1d(x_obs, M_true, U_true, E_true, t_obs)\n",
    "C_obs = C_true * (1 + 0.02 * np.random.randn(len(x_obs)))  # ruído de 2%\n",
    "\n",
    "# Plotar dados\n",
    "x_plot = np.linspace(2500, 6000, 200)\n",
    "C_plot = modelo_gaussiana_1d(x_plot, M_true, U_true, E_true, t_obs)\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.plot(x_plot, C_plot, 'b-', label='Modelo (parâmetros verdadeiros)')\n",
    "plt.scatter(x_obs, C_obs, c='red', s=50, label='Dados observados (com ruído)', zorder=5)\n",
    "plt.xlabel('Distância x [m]')\n",
    "plt.ylabel('Concentração C [kg/m³]')\n
    "plt.title('Dados sintéticos para calibração (t = 4 h)')\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"Dados gerados: {len(x_obs)} pontos, ruído σ = 2%\")\n",
    "print(f\"Pico teórico: x = {x_obs[0] + U_true*t_obs:.0f} m, C_max = {C_true.max():.4f} kg/m³\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔸 Levenberg-Marquardt para Calibração"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Estimativa inicial\n",
    "p0 = [30.0, 10.0]  # [M, E] - valores próximos dos verdadeiros\n",
    "\n",
    "# Calibração por Levenberg-Marquardt (scipy)\n",
    "result = least_squares(\n",
    "    residuos, p0, args=(x_obs, C_obs, U_true, t_obs),\n",
    "    method='trf',  # Trust Region Reflective\n",
    "    xtol=1e-8, ftol=1e-8, max_nfev=1000\n",
    ")\n",
    "\n",
    "# Parâmetros estimados\n",
    "M_est, E_est = result.x\n",
    "\n",
    "# Matriz Jacobiana e covariância\n",
    "J = result.jac\n",
    "n_params = len(result.x)\n",
    "n_obs = len(result.fun)\n",
    "sigma2 = np.sum(result.fun**2) / (n_obs - n_params)  # variância dos resíduos\n",
    "cov = sigma2 * np.linalg.inv(J.T @ J)\n",
    "std_err = np.sqrt(np.diag(cov))\n",
    "corr = cov[0,1] / np.sqrt(cov[0,0] * cov[1,1])\n",
    "\n",
    "# Resultados\n",
    "print(f\"\\nCalibração por Levenberg-Marquardt:\")\n",
    "print(f\"  Parâmetro  Verdadeiro  Estimado   Erro Padrão  IC 95%\")\n",
    "print(f\"  M [kg]     {M_true:8.2f}   {M_est:8.2f}   ±{std_err[0]:6.2f}   [{M_est-1.96*std_err[0]:.2f}, {M_est+1.96*std_err[0]:.2f}]\")\n",
    "print(f\"  E [m²/s]   {E_true:8.2f}   {E_est:8.2f}   ±{std_err[1]:6.3f}   [{E_est-1.96*std_err[1]:.2f}, {E_est+1.96*std_err[1]:.2f}]\")\n",
    "print(f\"\\nCorrelação entre parâmetros: ρ = {corr:.3f}\")\n",
    "print(f\"Função custo final: S = {result.cost*2:.3e}\")\n",
    "print(f\"Número de iterações: {result.nfev}\")\n",
    "\n",
    "# Plotar ajuste\n",
    "C_ajuste = modelo_gaussiana_1d(x_plot, M_est, U_true, E_est, t_obs)\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.plot(x_plot, C_plot, 'b--', label='Verdadeiro', alpha=0.7)\n",
    "plt.plot(x_plot, C_ajuste, 'r-', label='Ajustado', linewidth=2)\n",
    "plt.scatter(x_obs, C_obs, c='black', s=40, label='Dados', zorder=5)\n",
    "plt.xlabel('Distância x [m]')\n",
    "plt.ylabel('Concentração C [kg/m³]')\n",
    "plt.title('Ajuste do modelo gaussiano aos dados sintéticos')\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔸 Análise de Sensibilidade e Identificabilidade"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def sensibilidades_analiticas(x, M, E, U, t, x0=0):\n",
    "    \"\"\"\n",
    "    Calcula sensibilidades ∂C/∂M e ∂C/∂E analiticamente.\n",
    "    \"\"\"\n",
    "    sigma = np.sqrt(2 * E * t)\n",
    "    expo = -(x - x0 - U*t)**2 / (2 * sigma**2)\n",
    "    C = (M / (np.sqrt(2*np.pi) * sigma)) * np.exp(expo)\n",
    "    \n",
    "    # ∂C/∂M = C / M\n",
    "    dC_dM = C / M\n",
    "    \n",
    "    # ∂C/∂E (derivada em relação a sigma, depois em relação a E)\n",
    "    dC_dsigma = C * (-1/sigma + (x - x0 - U*t)**2 / sigma**3)\n",
    "    dsigma_dE = t / sigma\n",
    "    dC_dE = dC_dsigma * dsigma_dE\n",
    "    \n",
    "    return dC_dM, dC_dE, C\n",
    "\n",
    "# Calcular sensibilidades nos pontos observados\n",
    "dC_dM, dC_dE, C_calc = sensibilidades_analiticas(x_obs, M_est, E_est, U_true, t_obs)\n",
    "\n",
    "# Sensibilidades relativas normalizadas\n",
    "S_M = (M_est / C_calc) * dC_dM\n",
    "S_E = (E_est / C_calc) * dC_dE\n",
    "\n",
    "plt.figure(figsize=(10, 4))\n",
    "\n",
    "plt.subplot(1, 2, 1)\n",
    "plt.plot(x_obs, S_M, 'bo-', label='S_M = (M/C)·∂C/∂M')\n",
    "plt.xlabel('Distância x [m]')\n",
    "plt.ylabel('Sensibilidade relativa')\n",
    "plt.title('Sensibilidade em relação a M')\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.axhline(y=1, color='gray', linestyle=':', alpha=0.5)\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "plt.plot(x_obs, S_E, 'ro-', label='S_E = (E/C)·∂C/∂E')\n",
    "plt.xlabel('Distância x [m]')\n",
    "plt.ylabel('Sensibilidade relativa')\n",
    "plt.title('Sensibilidade em relação a E')\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.axhline(y=0, color='gray', linestyle=':', alpha=0.5)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"\\nAnálise de identificabilidade:\")\n",
    "print(f\"  Sensibilidade média a M: <|S_M|> = {np.mean(np.abs(S_M)):.3f}\")\n",
    "print(f\"  Sensibilidade média a E: <|S_E|> = {np.mean(np.abs(S_E)):.3f}\")\n",
    "if abs(corr) > 0.9:\n",
    "    print(f\"  ⚠ ALERTA: Alta correlação (|ρ| > 0.9) indica parâmetros compensatórios!\")\n",
    "    print(f\"    Estratégia: fixar um parâmetro ou adicionar dados em múltiplos tempos.\")\n",
    "else:\n",
    "    print(f\"  ✓ Parâmetros bem identificáveis (|ρ| = {abs(corr):.3f} < 0.9)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔸 Projeto: Calibração de Dispersão no Rio Macaé"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def calibrar_dispersao_rio(x_obs_list, C_obs_list, t_list, U, M, x0=3000):\n",
    "    \"\"\"\n",
    "    Calibra E_L e E_T simultaneamente usando dados em múltiplos tempos.\n",
    "    \n",
    "    Parâmetros:\n",
    "    -----------\n",
    "    x_obs_list : list of arrays\n",
    "        Posições de observação para cada tempo\n",
    "    C_obs_list : list of arrays\n",
    "        Concentrações observadas para cada tempo\n",
    "    t_list : array-like\n",
    "        Tempos de observação [s]\n",
    "    U, M, x0 : float\n",
    "        Parâmetros conhecidos\n",
    "    \n",
    "    Retorna:\n",
    "    --------\n",
    "    E_est, cov, stats : tuple\n",
    "        Parâmetros estimados, covariância e estatísticas\n",
    "    \"\"\"\n",
    "    def residuos_2D(params):\n",
    "        E_L, E_T = params\n",
    "        if E_L <= 0 or E_T <= 0:\n",
    "            return np.array([1e10])\n",
    "        \n",
    "        res = []\n",
    "        for x_obs, C_obs, t in zip(x_obs_list, C_obs_list, t_list):\n",
    "            # Solução 2D simplificada (integrada em y)\n",
    "            sigma_x = np.sqrt(2 * E_L * t)\n",
    "            C_calc = (M / (np.sqrt(2*np.pi) * sigma_x)) * np.exp(-(x_obs - x0 - U*t)**2 / (2*sigma_x**2))\n",
    "            res.extend(C_calc - C_obs)\n",
    "        return np.array(res)\n",
    "    \n",
    "    # Estimativa inicial\n",
    "    p0 = [10.0, 0.01]\n",
    "    \n",
    "    # Calibração\n",
    "    result = least_squares(residuos_2D, p0, method='trf', xtol=1e-8)\n",
    "    \n",
    "    # Covariância\n",
    "    J = result.jac\n",
    "    n_obs = len(result.fun)\n",
    "    n_params = 2\n",
    "    sigma2 = np.sum(result.fun**2) / (n_obs - n_params)\n",
    "    cov = sigma2 * np.linalg.inv(J.T @ J)\n",
    "    \n",
    "    return result.x, cov, {\n",
    "        'cost': result.cost*2,\n",
    "        'iterations': result.nfev,\n",
    "        'success': result.success\n",
    "    }\n",
    "\n",
    "# Exemplo com dados em 3 tempos\n",
    "t_vals = [2*3600, 4*3600, 6*3600]  # 2h, 4h, 6h\n",
    "x_obs_list = [x_obs + np.random.uniform(-50, 50, len(x_obs)) for _ in t_vals]\n",
    "C_obs_list = []\n",
    "\n",
    "for t in t_vals:\n",
    "    C_true_t = modelo_gaussiana_1d(x_obs, M_true, U_true, E_true, t)\n",
    "    C_obs_t = C_true_t * (1 + 0.02 * np.random.randn(len(x_obs)))\n",
    "    C_obs_list.append(C_obs_t)\n",
    "\n",
    "# Executar calibração\n",
    "E_est_2D, cov_2D, stats = calibrar_dispersao_rio(\n",
    "    [x_obs]*3, C_obs_list, t_vals, U_true, M_true\n",
    ")\n",
    "\n",
    "print(f\"\\nCalibração 2D (E_L, E_T) com múltiplos tempos:\")\n",
    "print(f\"  E_L estimado: {E_est_2D[0]:.2f} ± {np.sqrt(cov_2D[0,0]):.2f} m²/s\")\n",
    "print(f\"  E_T estimado: {E_est_2D[1]:.4f} ± {np.sqrt(cov_2D[1,1]):.4f} m²/s\")\n",
    "print(f\"  Custo final: S = {stats['cost']:.3e}\")\n",
    "print(f\"  Sucesso: {stats['success']}\")"
   ]
  },
