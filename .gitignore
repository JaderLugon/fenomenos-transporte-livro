# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# LaTeX auxiliares
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.bbl
*.blg
*.synctex.gz
*.fls
*.fdb_latexmk
*.run.xml

# Dados sensíveis
*.key
*.pem
*.env
!docs/.env.example

# QR Codes gerados (mantenha os templates)
qr/generated/
!qr/README.md
!qr/template.svg

# Resultados de testes
.pytest_cache/
coverage.xml
htmlcov/

# Modelos de IA grandes
models/*.pt
models/*.h5
!models/.gitkeep

# Logs
logs/
*.log
