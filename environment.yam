name: fen-trans
channels:
  - conda-forge
  - defaults
dependencies:
  - python=3.11
  - numpy>=1.24
  - scipy>=1.10
  - pandas>=2.0
  - matplotlib>=3.7
  - seaborn>=0.12
  - plotly>=5.14
  - jupyterlab>=4.0
  - ipywidgets>=8.0
  - qrcode>=7.4
  - pip
  - pip:
      - dashscope>=1.14.0
      - python-dotenv>=1.0.0
      - scikit-learn>=1.3.0
      - uncertainties>=3.1.7
      - tqdm>=4.65
      - pyyaml>=6.0
      - pytest>=7.3
      - black>=23.0